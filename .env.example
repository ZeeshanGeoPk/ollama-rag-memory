MIDDLEWARE_HOST=127.0.0.1
MIDDLEWARE_PORT=8080

LLM_OLLAMA_HOST=http://localhost:8000
EMBED_OLLAMA_HOST=http://localhost:8001

LLM_MODEL=phi4-mini:3.8b
EMBED_MODEL=nomic-embed-text:v1.5

OLLAMA_MODELS_DIR=.data/ollama_models
CHROMA_DIR=.data/chroma
SQLITE_PATH=.data/context.sqlite

RECENT_TURNS_TO_KEEP=6
RETRIEVAL_TOP_K=20
SENTENCE_SCORE_THRESHOLD=0.75
MAX_CONTEXT_TOKENS=12000

DEFAULT_CONVERSATION_ID=default
OLLAMA_BOOTSTRAP=true
