# IP/interface where the FastAPI middleware listens. Use 0.0.0.0 for LAN access.
MIDDLEWARE_HOST=127.0.0.1

# HTTP port exposed to the browser UI and Ollama-compatible clients.
MIDDLEWARE_PORT=8000

# Ollama server used for chat/generation. Keep it separate from embeddings.
LLM_OLLAMA_HOST=http://localhost:8001

# Ollama server used for nomic embeddings and Chroma retrieval.
EMBED_OLLAMA_HOST=http://localhost:8002

# Chat model forwarded to Ollama when a request does not specify another model.
LLM_MODEL=phi4-mini:3.8b

# Embedding model used for both stored chunks and incoming search queries.
EMBED_MODEL=nomic-embed-text:v1.5

# Shared Ollama model directory. Relative paths are resolved from the project root.
OLLAMA_MODELS_DIR=.data/ollama_models

# Persistent ChromaDB directory containing vector embeddings and metadata.
CHROMA_DIR=.data/chroma

# SQLite file containing complete RAG turns and browser conversation history.
SQLITE_PATH=.data/context.sqlite

# Number of newest turns considered recent context instead of vector-retrieved history.
# Higher values improve immediate continuity but consume more forwarded tokens.
RECENT_TURNS_TO_KEEP=6

# Maximum Chroma vector matches requested before grouping and token budgeting.
# Higher values improve recall but increase embedding-search and processing work.
RETRIEVAL_TOP_K=20

# Number of chunks restored before and after each matching vector chunk.
# Use 0 for only the matched chunk; 1 includes one neighbor on each side.
RETRIEVAL_CHUNK_NEIGHBORS=1

# true keeps a matching user question and assistant answer together; false uses only
# the turn containing the matching chunk.
RETRIEVAL_INCLUDE_TURN_PAIR=true

# Minimum blended semantic/keyword relevance for sentences from recent turns.
# Range: 0.0-1.0. Lower values retain more text; higher values prune more aggressively.
SENTENCE_SCORE_THRESHOLD=0.75

# Approximate maximum tokens of generated memory/recent context forwarded to the LLM.
# This excludes some caller-provided system-prompt overhead.
MAX_CONTEXT_TOKENS=2000

# Approximate token allowance reserved for compressed recent turns.
# Keep this plus RETRIEVED_CONTEXT_TOKENS at or below MAX_CONTEXT_TOKENS.
RECENT_CONTEXT_TOKENS=1300

# Approximate token allowance reserved for vector-retrieved historical memory.
RETRIEVED_CONTEXT_TOKENS=550

# Maximum relevant sentences retained from the latest assistant response.
# Older recent turns normally retain at most two relevant sentences.
MAX_RECENT_ASSISTANT_SENTENCES=4

# Fallback history namespace for API clients that omit conversation_id.
# Clients sharing this value also share one retrieval history.
DEFAULT_CONVERSATION_ID=default

# true starts missing Ollama servers and pulls missing models automatically.
# Set false when those servers and models are managed outside this application.
OLLAMA_BOOTSTRAP=true
